# MongoDB is hosted on MongoDB Atlas — there is no compose-level DB config.
#
# Copy the per-service env files and fill in secrets:
#   cp backend/.env.example backend/.env
#   cp agent-service/.env.example agent-service/.env
#   cp frontend/.env.example frontend/.env
#
# In backend/.env and agent-service/.env set MONGO_URI to your Atlas
# connection string (mongodb+srv://...).
