# Google OAuth client ID (same one used by the backend)
VITE_GOOGLE_CLIENT_ID=724659679309-stsfl9ou6nit7b4ofoqbeda7hguocquf.apps.googleusercontent.com

# Base URL of the backend API.
# - Local dev / single-origin Docker: leave EMPTY (uses the Vite/nginx proxy).
# - Production on Vercel: the frontend is a different origin than the backend,
#   so set this to your Render backend URL:
#       VITE_API_BASE=https://your-backend.onrender.com
#   (Also set backend COOKIE_SECURE=true and CLIENT_ORIGINS=your Vercel URL.)
VITE_API_BASE=
