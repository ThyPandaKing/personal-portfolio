# ============================================================================
# BACKEND ENV — local-dev defaults shown; production (Render) values in comments
# ============================================================================

# ---- Server ----
PORT=4000
NODE_ENV=development
# Comma-separated allowed frontend origins (CORS). Must include the exact origin
# the SPA is served from — no trailing slash.
#   prod: CLIENT_ORIGINS=https://your-app.vercel.app
CLIENT_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Database (MongoDB Atlas) ----
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=portfolio
MONGO_DB=portfolio

# ---- Auth ----
ADMIN_EMAILS=you@gmail.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=change-me-to-a-long-random-string
# Cookies:
#   local (same-origin via proxy):  COOKIE_DOMAIN empty,  COOKIE_SECURE=false  (SameSite=Lax)
#   prod  (Vercel ↔ Render, cross-site): COOKIE_DOMAIN empty, COOKIE_SECURE=true (SameSite=None)
# Leave COOKIE_DOMAIN blank unless you serve API + site on subdomains of one domain.
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ---- Agent service ----
# docker-compose: http://agent-service:8001   prod: https://your-agent.onrender.com
AGENT_SERVICE_URL=http://agent-service:8001
# Shared secret so the backend can call the agent's admin endpoints
# (must match INTERNAL_API_KEY in agent-service/.env)
INTERNAL_API_KEY=change-me-shared-with-backend

# ---- Uploads ----
# Files are stored in MongoDB GridFS (no local disk). This base URL is only used
# to build file links {PUBLIC_BASE_URL}/api/files/<id>; keep it as the backend's
# own public URL.   prod: PUBLIC_BASE_URL=https://your-backend.onrender.com
PUBLIC_BASE_URL=http://localhost:4000
