# ---- Server ----
PORT=8001
# Comma-separated allowed origins for CORS (backend + frontend)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5173

# ---- Gemini ----
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key
# Primary chat model.
GEMINI_MODEL=gemini-2.5-flash
# Optional fallback chain (comma-separated, tried in order, up to 3 attempts).
# If a model is down/over quota the next one is used; if all fail the reasoning
# is surfaced. Use currently-available models (check with ListModels);
# gemini-1.5-* has been retired.
GEMINI_MODELS=gemini-2.5-flash,gemini-flash-latest,gemini-2.0-flash
# Embeddings model (NOT part of the fallback chain — must stay constant;
# changing it requires re-creating the vector index with new EMBED_DIMS).
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# ---- Database (MongoDB Atlas) ----
# Use the same Atlas connection string as the backend. The agent reads portfolio
# data AND stores RAG vectors here (Atlas Vector Search) — one unified database.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority&appName=portfolio-agent
MONGO_DB=portfolio

# ---- Vector search (Atlas Vector Search, same DB) ----
VECTOR_COLLECTION=portfolio_vectors
VECTOR_INDEX=vector_index
# Embedding dimensions — must match GEMINI_EMBED_MODEL (gemini-embedding-001 = 3072).
EMBED_DIMS=3072

# ---- Shared secret so only the backend can call admin endpoints ----
INTERNAL_API_KEY=change-me-shared-with-backend
